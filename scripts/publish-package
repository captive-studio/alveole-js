#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -t 1 ]]; then
  RED=$'\033[31m'
  BLUE=$'\033[34m'
  RESET=$'\033[0m'
else
  RED=''
  BLUE=''
  RESET=''
fi

info() {
  printf "%b\n" "${BLUE}$*${RESET}"
}

error() {
  printf "%b\n" "${RED}$*${RESET}" >&2
}

stage_release_files() {
  git add \
    package-lock.json \
    packages/*/package.json

  local files=()

  while IFS= read -r -d '' file; do
    files+=("$file")
  done < <(
    find packages -type f \( \
      -path '*/src/generated/version.ts' \
      -o -name '*.stories.ts' \
      -o -name '*.stories.tsx' \
      -o -name '*.stories.sources.ts' \
      -o -name '*.stories.sources.tsx' \
    \) -print0
  )

  if [[ ${#files[@]} -gt 0 ]]; then
    git add -- "${files[@]}"
  else
    info "Aucun fichier généré de stories/version à ajouter."
  fi
}

trap 'rc=$?; if [[ $rc -ne 0 ]]; then error "Erreur: le script a échoué (code $rc)."; fi' ERR

# Détection du mode CI (tag poussé ou flag --ci)
CI_MODE=false
if [[ "${GITHUB_REF_TYPE:-}" == "tag" || "${GITHUB_REF:-}" == refs/tags/* ]]; then
  CI_MODE=true
fi
for arg in "$@"; do
  [[ "$arg" == "--ci" ]] && CI_MODE=true && break
done

# Liste des packages publiables (dossiers avec un package.json sous packages/)
get_packages() {
  for dir in packages/*/; do
    [[ -f "${dir}package.json" ]] || continue
    echo "${dir%/}"
  done
}

get_package_names() {
  while IFS= read -r pkg_dir; do
    node -p "require('./$pkg_dir/package.json').name"
  done <<< "$(get_packages)"
}

# Retourne les packages dans un ordre compatible avec les dépendances locales
# (dependencies/devDependencies/peerDependencies/optionalDependencies).
get_package_names_ordered() {
  node <<'NODE'
const fs = require('fs');
const path = require('path');

const root = process.cwd();
const packagesDir = path.join(root, 'packages');
const entries = fs
  .readdirSync(packagesDir, { withFileTypes: true })
  .filter((d) => d.isDirectory())
  .map((d) => path.join(packagesDir, d.name, 'package.json'))
  .filter((p) => fs.existsSync(p));

const pkgs = entries.map((pkgJsonPath) => {
  const json = JSON.parse(fs.readFileSync(pkgJsonPath, 'utf8'));
  return {
    name: json.name,
    dir: path.dirname(pkgJsonPath),
    json,
  };
});

const localNames = new Set(pkgs.map((p) => p.name));
const graph = new Map();
const indegree = new Map();

for (const pkg of pkgs) {
  graph.set(pkg.name, new Set());
  indegree.set(pkg.name, 0);
}

for (const pkg of pkgs) {
  const localDeps = new Set();
  for (const field of ['dependencies', 'devDependencies', 'peerDependencies', 'optionalDependencies']) {
    const deps = pkg.json[field] || {};
    for (const depName of Object.keys(deps)) {
      if (localNames.has(depName) && depName !== pkg.name) {
        localDeps.add(depName);
      }
    }
  }

  // Edge: dependency -> dependent (so dependencies are built first)
  for (const depName of localDeps) {
    if (!graph.get(depName).has(pkg.name)) {
      graph.get(depName).add(pkg.name);
      indegree.set(pkg.name, indegree.get(pkg.name) + 1);
    }
  }
}

const queue = Array.from(indegree.entries())
  .filter(([, deg]) => deg === 0)
  .map(([name]) => name)
  .sort();

const ordered = [];
while (queue.length > 0) {
  const name = queue.shift();
  ordered.push(name);
  const nexts = Array.from(graph.get(name)).sort();
  for (const next of nexts) {
    indegree.set(next, indegree.get(next) - 1);
    if (indegree.get(next) === 0) {
      queue.push(next);
      queue.sort();
    }
  }
}

if (ordered.length !== pkgs.length) {
  // Fallback stable: ordre alphabétique si cycle
  const remaining = pkgs.map((p) => p.name).sort();
  for (const name of remaining) {
    console.log(name);
  }
  process.exit(0);
}

for (const name of ordered) {
  console.log(name);
}
NODE
}

# --- Mode CI : build + publish uniquement ---
if [[ "$CI_MODE" == true ]]; then
  if [[ -z "${NPM_TOKEN:-}" ]]; then
    error "NPM_TOKEN manquant (requis en CI)."
    exit 1
  fi

  info "Configuration du token npm..."
  npm config set //registry.npmjs.org/:_authToken="$NPM_TOKEN"
  npm whoami

  echo ""
  info "Build de tous les packages..."
  while IFS= read -r name; do
    echo "  Build $name..."
    npm -w "$name" run build
  done <<< "$(get_package_names_ordered)"

  echo ""
  info "Publication sur npm..."
  while IFS= read -r name; do
    echo "  Publish $name..."
    npm -w "$name" publish --access public
  done <<< "$(get_package_names_ordered)"

  echo ""
  info "OK: tous les packages ont été publiés."
  exit 0
fi

# --- Mode release (local) ---
# NPM_TOKEN non requis en local (la publication est faite par la CI au push du tag)

CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
if [[ "$CURRENT_BRANCH" != "main" ]]; then
  error "Ce script de release doit être exécuté depuis la branche main (branche courante: ${CURRENT_BRANCH:-inconnue})."
  exit 1
fi

PACKAGE_DIRS=($(get_packages))
if [[ ${#PACKAGE_DIRS[@]} -eq 0 ]]; then
  error "Aucun package trouvé sous packages/."
  exit 1
fi

# Version actuelle (depuis le premier package)
FIRST_PKG="${PACKAGE_DIRS[0]}"
CURRENT_VERSION="$(node -p "require('./$FIRST_PKG/package.json').version")"

# Type de release : argument ou interactif
RELEASE_TYPE="${1:-}"
if [[ -z "$RELEASE_TYPE" ]]; then
  echo ""
  info "Version actuelle: $CURRENT_VERSION"
  info "Packages: ${PACKAGE_DIRS[*]}"
  echo ""
  read -r -p "Type de version (patch/minor/major): " RELEASE_TYPE
fi
case "$RELEASE_TYPE" in
  patch|minor|major) ;;
  *)
    error "Type invalide: $RELEASE_TYPE (patch, minor ou major attendu)."
    exit 1
    ;;
esac

# Calcul de la nouvelle version (via npm version dans un package temporaire)
NEW_VERSION="$(node -p "
  const v = '$CURRENT_VERSION'.split('.').map(Number);
  const type = '$RELEASE_TYPE';
  if (type === 'major') { v[0]++; v[1]=0; v[2]=0; }
  else if (type === 'minor') { v[1]++; v[2]=0; }
  else { v[2]++; }
  v.join('.');
")"

echo ""
info "Bump: $CURRENT_VERSION -> $NEW_VERSION ($RELEASE_TYPE)"

# Mise à jour de la version dans tous les packages
for pkg_dir in "${PACKAGE_DIRS[@]}"; do
  echo "  Mise à jour $pkg_dir/package.json..."
  node -e "
    const fs = require('fs');
    const p = '$pkg_dir/package.json';
    const j = JSON.parse(fs.readFileSync(p, 'utf8'));
    j.version = '$NEW_VERSION';
    fs.writeFileSync(p, JSON.stringify(j, null, 2) + '\n');
  "
done

echo ""
info "Mise à jour du package-lock.json..."
npm install --package-lock-only --ignore-scripts

echo ""
echo "Build de tous les packages..."
while IFS= read -r name; do
  echo "  Build $name..."
  npm -w "$name" run build
done <<< "$(get_package_names_ordered)"

echo ""
info "Commit et tag..."
stage_release_files
  
git commit -m "🔖 release v$NEW_VERSION"
git tag "v$NEW_VERSION"

echo ""
info "OK: release v$NEW_VERSION préparée."
echo ""
echo "Publication automatique : push du commit et du tag..."
git push && git push --tags
echo ""
info "OK: Le commit et le tag ont été poussés. La publication sur GitHub Actions va se déclencher automatiquement."
