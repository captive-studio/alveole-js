{
  "name": "@alveole/core",
  "version": "0.37.3",
  "description": "Core for Alveole.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test:unit": "NODE_OPTIONS=--max-old-space-size=4096 npx jest --maxWorkers=2 --ci"
  },
  "devDependencies": {
    "@alveole/eslint-config": "file:../eslint-config",
    "date-fns": "^4.1.0",
    "eslint": "^9.39.2"
  },
  "peerDependencies": {
    "date-fns": "*"
  },
  "dependencies": {
    "@uiw/react-signature": "^1.3.5",
    "react-native-signature-canvas": "^5.0.2"
  }
}
