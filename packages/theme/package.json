{
  "name": "@alveole/theme",
  "version": "0.37.2",
  "description": "Shared theme tokens and utilities.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rm -rf assets && cp -R src/assets assets",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "devDependencies": {
    "@alveole/eslint-config": "file:../eslint-config",
    "eslint": "^9.39.2"
  },
  "peerDependencies": {
    "@tamagui/core": "*",
    "expo-font": "*",
    "expo-system-ui": "*",
    "react": "*",
    "react-native": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@uiw/react-signature": "^1.3.5",
    "react-native-signature-canvas": "^5.0.2"
  }
}
