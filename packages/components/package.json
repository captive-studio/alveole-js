    "@tamagui/animations-css": "^1.129.0 <2.0.0",
    "@tamagui/avatar": "^1.129.0 <2.0.0",
    "@tamagui/config": "^1.129.0 <2.0.0",
    "@tamagui/dialog": "^1.129.0 <2.0.0",
    "@tamagui/popover": "^1.129.0 <2.0.0",
    "@tamagui/radio-group": "^1.129.0 <2.0.0",
