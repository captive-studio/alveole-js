{
  "name": "@alveole/components",
  "version": "0.36.1",
  "description": "Shared UI components.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./stories": {
      "types": "./dist/stories/index.d.ts",
      "default": "./dist/stories/index.js"
    },
    "./package.json": "./package.json",
    "./sync-pdfjs-web-assets": "./dist/scripts/sync-pdfjs-web-assets.mjs"
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run generate:sources && node ./scripts/generate-version.mjs && tsc -p tsconfig.build.json && node ./scripts/prepare-pdfjs-web-assets.mjs",
    "lint": "eslint .",
    "postinstall": "node ./scripts/postinstall.mjs",
    "test:unit": "NODE_OPTIONS=--max-old-space-size=4096 npx jest --maxWorkers=2 --ci",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "generate:sources": "node scripts/generate-stories-sources.mjs"
  },
  "devDependencies": {
    "@alveole/eslint-config": "file:../eslint-config",
    "@lucide/lab": "^0.1.2",
    "@shopify/flash-list": "^2.3.1",
    "@tamagui/config": "^1.144.4",
    "@tamagui/core": "^1.144.4",
    "@testing-library/react-native": "^13.3.3",
    "eslint": "^9.39.2",
    "expo": "~53.0.0",
    "expo-router": "~4.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.0",
    "lucide-react-native": "^1.11.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-native": "^0.79.2",
    "react-test-renderer": "^19.2.5",
    "tamagui": "^1.144.4"
  },
  "dependencies": {
    "zod": "^4.1.11"
  },
  "peerDependencies": {
    "@alveole/theme": "*",
    "@lottiefiles/dotlottie-react": "*",
    "@lucide/lab": "*",
    "@shopify/flash-list": ">=2",
    "@tamagui/accordion": "^1.129.0 <2.0.0",
    "@tamagui/animations-css": "^1.129.0 <2.0.0",
    "@tamagui/avatar": "^1.129.0 <2.0.0",
    "@tamagui/config": "^1.129.0 <2.0.0",
    "@tamagui/core": "^1.129.0 <2.0.0",
    "@tamagui/dialog": "^1.129.0 <2.0.0",
    "@tamagui/popover": "^1.129.0 <2.0.0",
    "@tamagui/radio-group": "^1.129.0 <2.0.0",
    "@tamagui/sheet": "^1.129.0 <2.0.0",
    "@tamagui/slider": "^1.129.0 <2.0.0",
    "@tamagui/switch": "^1.129.0 <2.0.0",
    "@tamagui/tabs": "^1.129.0 <2.0.0",
    "@tamagui/toast": "^1.129.0 <2.0.0",
    "expo-application": "*",
    "expo-constants": "*",
    "expo-image": "*",
    "expo-linear-gradient": "*",
    "expo-router": "*",
    "lottie-react-native": "*",
    "lucide-react-native": ">=0.570.0",
    "pdfjs-dist": "^4.0.0",
    "react": "*",
    "react-native": "*",
    "react-native-safe-area-context": "*",
    "react-native-svg": "^15.0.0",
    "react-native-webview": ">=13",
    "tamagui": "^1.129.0 <2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
